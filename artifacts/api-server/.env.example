# =============================================================================
# Star Atlantic Productions — API Server Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the server.
# Never commit .env to git.
# =============================================================================

# PostgreSQL connection string (required for database features)
DATABASE_URL=postgresql://user:password@localhost:5432/star_atlantic

# Port the API server listens on
PORT=5000

# -----------------------------------------------------------------------------
# Resend — Email Delivery (required for contact form emails)
# -----------------------------------------------------------------------------
# 1. Create a free account at https://resend.com
# 2. Go to Domains → Add Domain → add "staratlantic.com"
#    Follow the DNS instructions (add MX/TXT/CNAME records in your DNS provider)
# 3. Go to API Keys → Create API Key → copy and paste below
#
# Free tier: 100 emails/day, 3,000/month — more than enough for contact inquiries.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
